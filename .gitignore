# =====================
# MorgiFile GitIgnore
# =====================

# 🐍 Python
__pycache__/
*.pyc
*.pyo
*.pyd
.env
.venv
env/
venv/

# 📦 Node.js (Frontend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache
dist/
build/

# 🔍 IDE & Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# 🛡️ App Specific (Local Data/Temp)
# Note: Real database is in %APPDATA%/MorgiFile, 
# but we ignore local copies just in case.
morgifile.db
*.sqlite3
Safe/
Thumb/
Database/
Logs/
App/icon.png

# 📄 Reports & Local Scripts
optimization_report.md
*.log

# PyInstaller
*.spec
*.exe
build/
dist/

# Temp files
*_new
*~
